{
	"$schema": "https://static.modelcontextprotocol.io/schemas/2025-07-09/server.schema.json",
	"name": "io.github.sumup/mcp",
	"title": "SumUp MCP Servers",
	"description": "SumUp MCP servers for account/payment operations and developer documentation search.",
	"status": "active",
	"repository": {
		"url": "https://github.com/sumup/sumup-mcp",
		"source": "github"
	},
	"version": "1.0.0",
	"remotes": [
		{
			"type": "streamable-http",
			"url": "https://mcp.sumup.com/mcp",
			"headers": [
				{
					"name": "Authentication",
					"description": "SumUp API key for authentication.",
					"is_required": true,
					"is_secret": true
				}
			]
		},
		{
			"type": "streamable-http",
			"url": "https://docs.mcp.sumup.com/mcp"
		},
		{
			"type": "sse",
			"url": "https://mcp.sumup.com/sse",
			"headers": [
				{
					"name": "Authentication",
					"description": "SumUp API key for authentication.",
					"is_required": true,
					"is_secret": true
				}
			]
		},
		{
			"type": "sse",
			"url": "https://docs.mcp.sumup.com/sse"
		}
	]
}
